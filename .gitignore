# Python virtual environments
crop-circle-env/
cropbaudo-env/
venv/
.venv/
env/

# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Input images (user-supplied, not committed)
input_images/

# Temp upload files
/tmp/crop_input.*

# Pytest / testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Generated outputs (keep directory, ignore contents)
outputs/*
!outputs/.gitkeep

# Sample images (optionally track; ignore large files)
sample_images/*
!sample_images/.gitkeep

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment variables
.env
.env.*

# Logs
*.log
pip-log.txt

# MyPy
.mypy_cache/

# Ruff / linting
.ruff_cache/

# Annotated/processed images (stray outputs)
*.jpg
*.jpeg
*.png
*.bmp
*.tiff
!docs/**/*.png
!docs/**/*.jpg
